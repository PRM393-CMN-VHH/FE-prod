# Copy this file to .env and fill in the right host for how you're running
# the app. .env is gitignored — each developer keeps their own, so this
# value never needs to be edited in source code again.
#
# Which host to use:
#   - Backend running on a DIFFERENT machine on the same WiFi/hotspot
#     (this project's usual setup) -> that machine's LAN IP, e.g.
#     `ipconfig getifaddr en0` (macOS) or `ipconfig` (Windows) run ON the
#     backend machine, not the one running the emulator/app.
#   - Android Emulator (AVD) with the backend on the SAME machine as
#     Android Studio -> 10.0.2.2 (special alias to that machine's localhost)
#   - Web (flutter run -d chrome) -> localhost is used automatically, this
#     value is ignored
API_HOST=172.20.10.3
API_PORT=3636

# Alternative: set the full URL directly instead of HOST/PORT above
# (takes priority over API_HOST/API_PORT if set).
# API_BASE_URL=http://192.168.1.10:3636
