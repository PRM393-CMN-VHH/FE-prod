# Copy this file to .env and fill in your own machine's LAN IP/port.
# .env is gitignored — each developer keeps their own, so these values never
# need to be edited in source code again.
#
# Find your IP: `ipconfig getifaddr en0` (macOS) or `ipconfig` (Windows).
API_HOST=192.168.1.10
API_PORT=3636

# Alternative: set the full URL directly instead of HOST/PORT above
# (takes priority over API_HOST/API_PORT if set).
# API_BASE_URL=http://192.168.1.10:3636
